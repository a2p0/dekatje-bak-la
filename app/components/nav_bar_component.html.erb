<nav class="flex items-center justify-between px-4 py-3 bg-white dark:bg-slate-900/95 border-b border-slate-200 dark:border-indigo-500/15 backdrop-blur-sm"
     data-controller="nav-menu">
  <%# Left: brand + optional breadcrumb %>
  <div class="flex items-center gap-3 min-w-0">
    <% if brand? %>
      <div class="text-base font-bold bg-gradient-to-br from-indigo-500 to-violet-500 bg-clip-text text-transparent whitespace-nowrap">
        <%= brand %>
      </div>
    <% end %>
    <% if breadcrumb? %>
      <div class="hidden sm:block text-slate-400 dark:text-slate-600">|</div>
      <div class="hidden sm:block min-w-0 truncate">
        <%= breadcrumb %>
      </div>
    <% end %>
  </div>

  <%# Desktop: links + actions visible %>
  <div class="hidden md:flex items-center gap-6">
    <% if links? %>
      <div class="flex items-center gap-4">
        <% links.each do |link| %>
          <%= link %>
        <% end %>
      </div>
    <% end %>
    <% if actions? %>
      <div class="flex items-center gap-3">
        <%= actions %>
      </div>
    <% end %>
  </div>

  <%# Mobile: burger button %>
  <button data-action="click->nav-menu#toggle" data-nav-menu-target="button"
          class="md:hidden p-2 rounded-lg text-slate-500 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-700 cursor-pointer"
          aria-label="Menu">
    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
    </svg>
  </button>

  <%# Mobile dropdown %>
  <div data-nav-menu-target="menu"
       class="hidden md:hidden absolute top-[57px] left-0 right-0 bg-white dark:bg-slate-800 border-b border-slate-200 dark:border-slate-700 shadow-lg z-40 px-4 py-3">
    <div class="flex flex-col gap-3">
      <% if links? %>
        <% links.each do |link| %>
          <%= link %>
        <% end %>
      <% end %>
      <% if actions? %>
        <div class="flex flex-wrap items-center gap-3 pt-2 border-t border-slate-200 dark:border-slate-700">
          <%= actions %>
        </div>
      <% end %>
    </div>
  </div>
</nav>

<div class="min-h-screen flex items-center justify-center px-4 bg-slate-50 dark:bg-slate-950">
  <div class="w-full max-w-md">
    <div class="bg-white dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-slate-800 shadow-sm p-6">
      <h1 class="text-2xl font-bold text-slate-800 dark:text-slate-100 mb-6">Créer un compte</h1>

      <% if resource.errors.any? %>
        <div class="bg-rose-50 dark:bg-rose-900/20 border border-rose-200 dark:border-rose-800 rounded-lg p-4 mb-4">
          <ul class="text-sm text-rose-700 dark:text-rose-300 list-disc list-inside space-y-1">
            <% resource.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%= form_with(model: resource, as: resource_name, url: registration_path(resource_name), data: { turbo: false }) do |f| %>
        <div class="mb-4">
          <%= f.label :first_name, "Prénom", class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1" %>
          <%= f.text_field :first_name,
              autofocus: true,
              autocomplete: "given-name",
              class: "w-full rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 text-sm px-3 py-2 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent dark:text-slate-100" %>
        </div>

        <div class="mb-4">
          <%= f.label :last_name, "Nom", class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1" %>
          <%= f.text_field :last_name,
              autocomplete: "family-name",
              class: "w-full rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 text-sm px-3 py-2 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent dark:text-slate-100" %>
        </div>

        <div class="mb-4">
          <%= f.label :email, "Email", class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1" %>
          <%= f.email_field :email,
              autocomplete: "email",
              class: "w-full rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 text-sm px-3 py-2 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent dark:text-slate-100" %>
        </div>

        <div class="mb-4">
          <%= f.label :password, "Password", class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1" %>
          <% if @minimum_password_length %>
            <p class="text-xs text-slate-500 dark:text-slate-400 mb-1"><%= @minimum_password_length %> caractères minimum</p>
          <% end %>
          <%= f.password_field :password,
              autocomplete: "new-password",
              class: "w-full rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 text-sm px-3 py-2 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent dark:text-slate-100" %>
        </div>

        <div class="mb-4">
          <%= f.label :password_confirmation, "Password confirmation", class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1" %>
          <%= f.password_field :password_confirmation,
              autocomplete: "new-password",
              class: "w-full rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 text-sm px-3 py-2 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent dark:text-slate-100" %>
        </div>

        <div class="mt-6">
          <%= render(ButtonComponent.new(variant: :primary, size: :md, type: "submit", class: "w-full")) do %>
            S'inscrire
          <% end %>
        </div>
      <% end %>

      <div class="mt-4 text-center">
        <%= link_to "Déjà inscrit ? Se connecter", new_user_session_path, class: "text-sm text-indigo-600 dark:text-indigo-400 hover:underline" %>
      </div>
    </div>
  </div>
</div>

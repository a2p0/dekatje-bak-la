<%
  # Pre-compute navigation targets
  idx = @questions_in_part.index(@question).to_i
  prev_q = idx > 0 ? @questions_in_part[idx - 1] : nil
  next_q = idx < @questions_in_part.size - 1 ? @questions_in_part[idx + 1] : nil

  total = @questions_in_part.size
  answered = @session_record.answered_count_for(@questions_in_part)

  # Navigation hrefs
  prev_href = prev_q && student_question_path(access_code: params[:access_code], subject_id: @subject.id, id: prev_q.id)
  next_href = if params[:from] == "review"
                student_subject_path(access_code: params[:access_code], id: @subject.id)
              elsif next_q
                student_question_path(access_code: params[:access_code], subject_id: @subject.id, id: next_q.id)
              end

  # End-of-part button: "Partie suivante" (intermediate) or "Fin de la partie ..." (section terminal)
  parts_in_section = parts_in_same_section(@parts, @part)
  part_idx_in_section = parts_in_section.index(@part)
  next_part_in_section = part_idx_in_section && parts_in_section[part_idx_in_section + 1]
  next_part_first_question = next_part_in_section&.questions&.kept&.order(:position)&.first

  section_label = @part.section_type == "specific" ? "spécifique" : "commune"
  end_of_part_label = next_part_in_section ? "Partie suivante →" : "Fin de la partie #{section_label}"
  end_of_part_mobile_label = next_part_in_section ? "Partie suivante →" : "Fin partie →"
%>

<div data-controller="sidebar"
     class="flex min-h-[calc(100vh-57px)] pb-20 lg:pb-0">

  <%# Backdrop (mobile only) %>
  <div data-sidebar-target="backdrop"
       data-action="click->sidebar#close"
       class="hidden fixed inset-0 bg-black/50 z-[var(--z-backdrop)] lg:hidden">
  </div>

  <%# Sidebar / Drawer — stays dark in both modes %>
  <aside id="sidebar-drawer"
         data-sidebar-target="drawer"
         data-controller="focus-trap"
         data-action="focus-trap:close->sidebar#close"
         aria-label="Navigation du sujet"
         class="w-[260px] bg-slate-900 border-r border-indigo-500/10 flex-shrink-0 overflow-y-auto
                fixed top-0 left-0 bottom-0 z-[var(--z-sidebar)] -translate-x-full transition-transform duration-200
                lg:relative lg:translate-x-0 lg:z-auto">
    <%= render "student/questions/sidebar",
        subject: @subject,
        current_part: @part,
        current_question: @question,
        parts: @parts,
        questions_in_part: @questions_in_part,
        session_record: @session_record,
        access_code: params[:access_code] %>
  </aside>

  <%# Main content %>
  <div class="flex-1 px-4 py-5 max-w-3xl mx-auto w-full">

    <%# Breadcrumb %>
    <div class="mb-3">
      <%= render(BreadcrumbComponent.new(items: [
        { label: "Mes sujets", href: student_root_path(access_code: params[:access_code]) },
        { label: @subject.title, href: student_subject_path(access_code: params[:access_code], id: @subject.id) },
        { label: "Partie #{@part.number}", href: student_subject_path(access_code: params[:access_code], id: @subject.id, part_id: @part.id) },
        { label: "Q#{@question.number}" }
      ])) %>
    </div>

    <%# Progress bar row %>
    <div class="flex items-center gap-2.5 mb-4">
      <button data-action="click->sidebar#open"
              data-sidebar-target="toggle"
              aria-label="Ouvrir le menu"
              aria-expanded="false"
              aria-controls="sidebar-drawer"
              class="w-9 h-9 flex items-center justify-center bg-slate-100 dark:bg-slate-800 border-0 rounded-lg text-slate-600 dark:text-slate-400 text-lg cursor-pointer hover:bg-slate-200 dark:hover:bg-slate-700 transition-colors lg:hidden">
        ☰
      </button>
      <span class="text-slate-600 dark:text-slate-400 text-sm whitespace-nowrap">
        Q<%= @question.number %> (<%= idx + 1 %>/<%= total %>)
      </span>
      <div class="flex-1">
        <%= render(ProgressBarComponent.new(current: answered, total: total, color: :gradient)) %>
      </div>
      <%# Tutorat button — larger on desktop with gradient %>
      <button data-action="click->chat#open"
              data-chat-target="toggle"
              aria-label="Ouvrir le tutorat IA"
              aria-expanded="false"
              aria-controls="chat-drawer"
              class="hidden lg:inline-flex items-center gap-2 px-4 py-2 bg-gradient-to-br from-indigo-500 to-violet-500 text-white border-0 rounded-xl text-sm font-semibold cursor-pointer whitespace-nowrap hover:from-indigo-600 hover:to-violet-600 transition-all shadow-[0_0_16px_rgba(99,102,241,0.3)]">
        💬 Tutorat
      </button>
    </div>

    <%# Sticky part title %>
    <div class="sticky top-0 z-10 bg-slate-50/95 dark:bg-slate-950/95 backdrop-blur-sm -mx-4 px-4 py-2 mb-4 border-b border-slate-200 dark:border-indigo-500/10">
      <p class="text-sm font-semibold text-slate-800 dark:text-slate-200">
        Partie <%= @part.number %> — <%= @part.title %>
      </p>
    </div>

    <%# Context card (separate, above question) %>
    <% if @question.context_text.present? %>
      <div class="bg-slate-50 dark:bg-slate-800/60 rounded-2xl p-5 mb-3 border border-slate-200 dark:border-slate-700/50">
        <p class="text-slate-600 dark:text-slate-300 text-sm leading-relaxed italic"><%= @question.context_text %></p>
      </div>
    <% end %>

    <%# Question card (glow) %>
    <div class="bg-white/80 dark:bg-slate-900/60 rounded-2xl p-5 mb-4 border border-slate-200 dark:border-indigo-500/15 shadow-sm dark:shadow-[0_0_20px_rgba(99,102,241,0.05)]">
      <div class="flex flex-wrap items-center gap-2 mb-3">
        <span class="text-indigo-600 dark:text-indigo-400 font-semibold text-sm">Question <%= @question.number %></span>
        <% Array(@question.dt_references).each do |dt_ref| %>
          <%= render(BadgeComponent.new(color: :blue, label: dt_ref)) %>
        <% end %>
        <% Array(@question.dr_references).each do |dr_ref| %>
          <%= render(BadgeComponent.new(color: :amber, label: dr_ref)) %>
        <% end %>
      </div>
      <p class="text-slate-800 dark:text-slate-100 text-sm leading-relaxed mb-2"><%= @question.label %></p>
    </div>

    <%# Spotting card (tutored mode only) %>
    <% if @session_record.tutored? && @question.answer %>
      <% if !@session_record.spotting_completed?(@question.id) %>
        <%= render "student/tutor/spotting_card",
            question: @question, subject: @subject,
            session_record: @session_record, access_code: params[:access_code] %>
      <% else %>
        <% spotting = @session_record.spotting_data(@question.id) %>
        <% if spotting %>
          <%= render "student/tutor/spotting_feedback",
              question: @question, spotting: spotting %>
        <% end %>
      <% end %>
    <% end %>

    <%# Correction + data hints area %>
    <%= turbo_frame_tag "question_#{@question.id}_correction" do %>
      <% if @session_record.answered?(@question.id) %>
        <%= render "student/questions/correction",
            question: @question, subject: @subject, session_record: @session_record %>
      <% elsif @question.answer && (!@session_record.tutored? || @session_record.spotting_completed?(@question.id)) %>
        <div class="flex flex-wrap items-center justify-center gap-4 mb-4">
          <%= button_to "Voir la correction",
              student_subject_question_correction_path(access_code: params[:access_code], subject_id: @subject.id, question_id: @question.id),
              method: :post,
              data: { turbo_frame: "question_#{@question.id}_correction" },
              class: "px-8 py-3 bg-gradient-to-br from-indigo-500 to-violet-500 text-white border-0 rounded-xl text-sm cursor-pointer hover:from-indigo-600 hover:to-violet-600 transition-all font-semibold shadow-[0_0_16px_rgba(99,102,241,0.3)]" %>
        </div>
      <% end %>
    <% end %>

    <%# Desktop navigation (hidden on mobile — bottom bar handles it) %>
    <div class="hidden lg:flex justify-between items-center pt-4 border-t border-slate-200 dark:border-indigo-500/10 mt-2">
      <% if prev_q %>
        <%= link_to "← Q#{prev_q.number}",
            prev_href,
            class: "text-indigo-600 dark:text-indigo-400 text-sm no-underline hover:text-indigo-700 dark:hover:text-indigo-300 transition-colors" %>
      <% else %>
        <span></span>
      <% end %>

      <% if next_href && next_q %>
        <%= link_to "Question suivante →",
            next_href,
            class: "inline-flex items-center px-6 py-2.5 bg-gradient-to-br from-emerald-500 to-emerald-600 text-white rounded-xl text-sm font-semibold no-underline hover:from-emerald-600 hover:to-emerald-700 transition-all" %>
      <% elsif params[:from] == "review" %>
        <%= link_to "Question suivante →",
            next_href,
            class: "inline-flex items-center px-6 py-2.5 bg-gradient-to-br from-emerald-500 to-emerald-600 text-white rounded-xl text-sm font-semibold no-underline hover:from-emerald-600 hover:to-emerald-700 transition-all" %>
      <% elsif next_part_in_section && next_part_first_question %>
        <%# Last question of an intermediate part → go to first question of next part in same section %>
        <%= link_to end_of_part_label,
            student_question_path(access_code: params[:access_code], subject_id: @subject.id, id: next_part_first_question.id),
            class: "inline-flex items-center px-6 py-2.5 bg-gradient-to-br from-emerald-500 to-emerald-600 text-white rounded-xl text-sm font-semibold no-underline hover:from-emerald-600 hover:to-emerald-700 transition-all" %>
      <% else %>
        <%# Last question of the last part in its section → mark part done and route to other section %>
        <%= button_to end_of_part_label,
            student_subject_part_completion_path(access_code: params[:access_code], subject_id: @subject.id, part_id: @part.id),
            method: :post,
            class: "inline-flex items-center px-6 py-2.5 bg-gradient-to-br from-emerald-500 to-emerald-600 text-white rounded-xl text-sm font-semibold border-0 cursor-pointer hover:from-emerald-600 hover:to-emerald-700 transition-all" %>
      <% end %>
    </div>
  </div>

  <%# Mobile bottom bar (hidden on lg+) %>
  <div class="lg:hidden fixed bottom-0 left-0 right-0 z-[var(--z-bottom-bar)] bg-white/95 dark:bg-slate-900/95 border-t border-slate-200 dark:border-indigo-500/15 backdrop-blur-sm px-4 py-3 flex items-center gap-3">
    <% if prev_q %>
      <%= link_to prev_href,
          class: "flex-1 min-w-0 text-left text-sm text-slate-600 dark:text-slate-400 hover:text-indigo-600 dark:hover:text-indigo-400 truncate no-underline" do %>
        &larr; Q<%= prev_q.number %>
      <% end %>
    <% else %>
      <span class="flex-1"></span>
    <% end %>

    <button data-action="click->chat#open"
            data-chat-target="toggle"
            aria-label="Ouvrir le tutorat IA"
            aria-expanded="false"
            aria-controls="chat-drawer"
            class="flex-shrink-0 inline-flex items-center gap-1.5 px-4 py-2 bg-gradient-to-br from-indigo-500 to-violet-500 text-white border-0 rounded-xl text-sm font-semibold cursor-pointer whitespace-nowrap shadow-[0_0_14px_rgba(99,102,241,0.3)]">
      💬 Tutorat
    </button>

    <% if next_href %>
      <%= link_to next_href,
          class: "flex-1 min-w-0 text-right text-sm font-semibold text-emerald-600 dark:text-emerald-400 truncate no-underline" do %>
        <%= next_q ? "Q#{next_q.number}" : (params[:from] == 'review' ? "Retour" : "Suivante") %> &rarr;
      <% end %>
    <% elsif next_part_in_section && next_part_first_question %>
      <%= link_to student_question_path(access_code: params[:access_code], subject_id: @subject.id, id: next_part_first_question.id),
          class: "flex-1 min-w-0 text-right text-sm font-semibold text-emerald-600 dark:text-emerald-400 truncate no-underline" do %>
        <%= end_of_part_mobile_label %>
      <% end %>
    <% else %>
      <div class="flex-1 min-w-0 text-right">
        <%= button_to end_of_part_mobile_label,
            student_subject_part_completion_path(access_code: params[:access_code], subject_id: @subject.id, part_id: @part.id),
            method: :post,
            class: "text-sm font-semibold text-emerald-600 dark:text-emerald-400 truncate border-0 bg-transparent cursor-pointer p-0" %>
      </div>
    <% end %>
  </div>

</div>

<div data-controller="sidebar chat"
     data-chat-create-url-value="<%= student_conversations_path(access_code: params[:access_code]) %>"
     data-chat-message-url-value=""
     data-chat-question-id-value="<%= @question.id %>"
     data-chat-has-api-key-value="<%= current_student.api_key.present? %>"
     data-chat-settings-url-value="<%= student_settings_path(access_code: params[:access_code]) %>"
     data-chat-conversation-id-value="<%= @conversation&.id %>"
     class="flex min-h-screen">

  <%# Backdrop (mobile only) %>
  <div data-sidebar-target="backdrop"
       data-action="click->sidebar#close"
       class="hidden fixed inset-0 bg-black/50 z-40 lg:hidden">
  </div>

  <%# Sidebar / Drawer %>
  <aside data-sidebar-target="drawer"
         class="w-[260px] bg-slate-900 border-r border-slate-800 flex-shrink-0 overflow-y-auto
                fixed top-0 left-0 bottom-0 z-50 -translate-x-full transition-transform duration-200
                lg:relative lg:translate-x-0 lg:z-auto">
    <%= render "student/questions/sidebar",
        subject: @subject,
        current_part: @part,
        current_question: @question,
        parts: @parts,
        questions_in_part: @questions_in_part,
        session_record: @session_record,
        access_code: params[:access_code] %>
  </aside>

  <%# Main content %>
  <div class="flex-1 px-4 py-5 max-w-3xl mx-auto w-full">

    <%# Top bar %>
    <div class="flex items-center gap-2.5 mb-4">
      <button data-action="click->sidebar#open"
              class="w-9 h-9 flex items-center justify-center bg-slate-800 border-0 rounded-md text-slate-400 text-lg cursor-pointer hover:bg-slate-700 transition-colors lg:hidden"
              aria-label="Ouvrir le menu">
        ☰
      </button>
      <span class="text-slate-400 text-[13px]">
        Q<%= @question.number %>
        (<%= @questions_in_part.index(@question).to_i + 1 %>/<%= @questions_in_part.size %>)
      </span>
      <%
        total = @questions_in_part.size
        answered = @questions_in_part.count { |q| @session_record.answered?(q.id) }
      %>
      <div class="flex-1">
        <%= render(ProgressBarComponent.new(current: answered, total: total, color: :indigo)) %>
      </div>
      <button data-action="click->chat#open"
              class="px-3.5 py-1.5 bg-indigo-600 text-white border-0 rounded-md text-[13px] cursor-pointer whitespace-nowrap hover:bg-indigo-700 transition-colors">
        Tutorat
      </button>
    </div>

    <%# Sticky part title %>
    <div class="sticky top-0 z-10 bg-slate-950/95 backdrop-blur-sm -mx-4 px-4 py-2 mb-4 border-b border-slate-800">
      <p class="text-sm font-semibold text-slate-200">
        Partie <%= @part.number %> — <%= @part.title %>
      </p>
    </div>

    <%# Collapsible mise en situation + objectif — open on first question if no answers yet %>
    <% first_visit = @questions_in_part.index(@question).to_i == 0 && @questions_in_part.none? { |q| @session_record.answered?(q.id) } %>
    <details class="mb-5 bg-slate-800/50 border border-slate-700 rounded-lg overflow-hidden" data-context-panel <%= "open" if first_visit %>>
      <summary class="flex items-center justify-between px-4 py-3 cursor-pointer select-none hover:bg-slate-800/80 list-none">
        <span class="text-sm font-medium text-slate-300">Mise en situation & objectif</span>
        <svg class="w-4 h-4 text-slate-400 transition-transform [details[open]>&]:rotate-180"
             fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
        </svg>
      </summary>
      <div class="px-4 pb-4 border-t border-slate-700">
        <div class="mt-3 mb-3">
          <p class="text-[10px] uppercase tracking-wider text-slate-500 mb-1">Mise en situation</p>
          <p class="text-sm text-slate-300 leading-relaxed"><%= @subject.presentation_text %></p>
        </div>
        <div>
          <p class="text-[10px] uppercase tracking-wider text-slate-500 mb-1">Objectif</p>
          <p class="text-sm text-slate-300 leading-relaxed"><%= @part.objective_text %></p>
        </div>
      </div>
    </details>

    <%# Question card %>
    <div class="bg-slate-800 rounded-lg p-4 mb-4 border border-slate-700">
      <div class="flex justify-between items-center mb-2">
        <div class="flex items-center gap-2">
          <span class="text-indigo-400 font-semibold text-sm">Question <%= @question.number %></span>
          <% doc_refs = @question.answer&.data_hints&.select { |h| h["source"].to_s.match?(/\ADT|DR/i) }&.map { |h| h["source"] }&.uniq || [] %>
          <% doc_refs.each do |ref| %>
            <%= render(BadgeComponent.new(color: ref.start_with?("DT") ? :blue : :amber, label: ref)) %>
          <% end %>
        </div>
        <%= render(BadgeComponent.new(color: :indigo, label: "#{@question.points} pts")) %>
      </div>
      <p class="text-slate-200 text-sm leading-relaxed mb-2"><%= @question.label %></p>
      <% if @question.context_text.present? %>
        <p class="text-slate-400 text-[13px] leading-snug italic"><%= @question.context_text %></p>
      <% end %>
    </div>

    <%# Correction area %>
    <%= turbo_frame_tag "question_#{@question.id}_correction" do %>
      <% if @session_record.answered?(@question.id) %>
        <%= render "student/questions/correction",
            question: @question, subject: @subject, session_record: @session_record %>
      <% elsif @question.answer %>
        <div class="text-center mb-4">
          <%= button_to "Voir la correction",
              student_reveal_question_path(access_code: params[:access_code], subject_id: @subject.id, id: @question.id),
              method: :patch,
              data: { turbo_frame: "question_#{@question.id}_correction" },
              class: "px-8 py-3 bg-indigo-600 text-white border-0 rounded-lg text-sm cursor-pointer hover:bg-indigo-700 transition-colors font-semibold" %>
        </div>
      <% end %>
    <% end %>

    <%# Navigation %>
    <%
      idx = @questions_in_part.index(@question).to_i
      prev_q = idx > 0 ? @questions_in_part[idx - 1] : nil
      next_q = idx < @questions_in_part.size - 1 ? @questions_in_part[idx + 1] : nil
    %>
    <div class="flex justify-between items-center pt-4 border-t border-slate-800 mt-2">
      <% if prev_q %>
        <%= link_to "← Q#{prev_q.number}",
            student_question_path(access_code: params[:access_code], subject_id: @subject.id, id: prev_q.id),
            class: "text-indigo-400 text-[13px] no-underline hover:text-indigo-300 transition-colors" %>
      <% else %>
        <span></span>
      <% end %>

      <% if next_q %>
        <%= link_to "Question suivante →",
            student_question_path(access_code: params[:access_code], subject_id: @subject.id, id: next_q.id),
            class: "inline-flex items-center px-6 py-2.5 bg-emerald-600 text-white rounded-lg text-[13px] font-semibold no-underline hover:bg-emerald-700 transition-colors" %>
      <% else %>
        <%= link_to "Retour aux sujets",
            student_root_path(access_code: params[:access_code]),
            class: "inline-flex items-center px-6 py-2.5 bg-emerald-600 text-white rounded-lg text-[13px] font-semibold no-underline hover:bg-emerald-700 transition-colors" %>
      <% end %>
    </div>
  </div>

  <%# Chat drawer %>
  <%= render "student/questions/chat_drawer", conversation: @conversation %>
</div>

<%# Sidebar content — documents, presentations, parts/questions, settings %>
<div class="p-4">

  <%# Documents %>
  <% if subject.new_format? %>
    <p class="text-slate-500 text-[10px] uppercase tracking-wide mb-2">Documents</p>
    <%= link_to rails_blob_path(subject.subject_pdf, disposition: "inline"),
        target: "_blank",
        class: "flex items-center gap-1.5 text-blue-400 text-xs my-1 no-underline hover:text-blue-300 transition-colors" do %>
      <%= render(BadgeComponent.new(color: :blue, label: "PDF")) %>
      <span>Sujet complet</span>
    <% end %>
    <% if session_record.answered?(current_question.id) %>
      <%= link_to rails_blob_path(subject.correction_pdf, disposition: "inline"),
          target: "_blank",
          class: "flex items-center gap-1.5 text-emerald-400 text-xs my-1 no-underline hover:text-emerald-300 transition-colors" do %>
        <%= render(BadgeComponent.new(color: :emerald, label: "PDF")) %>
        <span>Corrigé complet</span>
      <% end %>
    <% end %>
    <hr class="border-slate-700 my-3">
  <% else %>
    <% has_docs = subject.dt_file.attached? || subject.dr_vierge_file.attached? %>
    <% if has_docs %>
      <p class="text-slate-500 text-[10px] uppercase tracking-wide mb-2">Documents</p>
      <% if subject.dt_file.attached? %>
        <%= link_to rails_blob_path(subject.dt_file, disposition: "inline"),
            target: "_blank",
            class: "flex items-center gap-1.5 text-blue-400 text-xs my-1 no-underline hover:text-blue-300 transition-colors" do %>
          <%= render(BadgeComponent.new(color: :blue, label: "DT")) %>
          <span>Documents Techniques</span>
        <% end %>
      <% end %>
      <% if subject.dr_vierge_file.attached? %>
        <%= link_to rails_blob_path(subject.dr_vierge_file, disposition: "attachment"),
            class: "flex items-center gap-1.5 text-amber-400 text-xs my-1 no-underline hover:text-amber-300 transition-colors" do %>
          <%= render(BadgeComponent.new(color: :amber, label: "DR")) %>
          <span>DR vierge</span>
        <% end %>
      <% end %>
      <% if session_record.answered?(current_question.id) %>
        <% if subject.dr_corrige_file.attached? %>
          <%= link_to rails_blob_path(subject.dr_corrige_file, disposition: "inline"),
              target: "_blank",
              class: "flex items-center gap-1.5 text-emerald-400 text-xs my-1 no-underline hover:text-emerald-300 transition-colors" do %>
            <%= render(BadgeComponent.new(color: :emerald, label: "DR")) %>
            <span>DR corrigé</span>
          <% end %>
        <% end %>
      <% end %>
      <hr class="border-slate-700 my-3">
    <% end %>
  <% end %>

  <%# Context — presentations (commune before Partie 1, specifique before first specific part) %>
  <% has_common_presentation = subject.common_presentation.present? %>
  <% has_specific_presentation = subject.specific_presentation.present? %>
  <% if has_common_presentation || has_specific_presentation %>
    <p class="text-slate-500 text-[10px] uppercase tracking-wide mb-2">Contexte</p>
    <% if has_common_presentation %>
      <%= link_to student_subject_path(access_code: access_code, id: subject.id),
          class: "flex items-center gap-1.5 text-slate-400 text-xs my-1 no-underline hover:text-indigo-300 transition-colors" do %>
        <span>📋</span>
        <span>Présentation commune</span>
      <% end %>
    <% end %>
    <% if has_specific_presentation %>
      <%
        first_specific = parts.order(:position).find { |p| p.section_type == "specific" }
        specific_q = first_specific&.questions&.kept&.order(:position)&.first
      %>
      <% if specific_q %>
        <%= link_to student_question_path(access_code: access_code, subject_id: subject.id, id: specific_q.id, show_specific_presentation: true),
            class: "flex items-center gap-1.5 text-slate-400 text-xs my-1 no-underline hover:text-indigo-300 transition-colors" do %>
          <span>📋</span>
          <span>Présentation spécifique</span>
        <% end %>
      <% end %>
    <% end %>
    <hr class="border-slate-700 my-3">
  <% end %>

  <%# All parts grouped by section_type (commune / specifique) %>
  <%
    ordered_parts = parts.order(:position).to_a
    common_parts = ordered_parts.select { |p| p.section_type == "common" }
    specific_parts = ordered_parts.select { |p| p.section_type == "specific" }
    show_section_headers = common_parts.any? && specific_parts.any?
  %>

  <% if show_section_headers && common_parts.any? %>
    <p class="text-slate-500 text-[10px] uppercase tracking-wide mb-1 mt-2 font-semibold px-2">Partie commune</p>
  <% end %>
  <% common_parts.each do |p| %>
    <%= render "student/questions/sidebar_part",
        part: p,
        current_part: current_part,
        current_question: current_question,
        session_record: session_record,
        subject: subject,
        access_code: access_code %>
  <% end %>

  <% if show_section_headers && specific_parts.any? %>
    <p class="text-slate-500 text-[10px] uppercase tracking-wide mb-1 mt-4 font-semibold px-2">Partie spécifique</p>
  <% end %>
  <% specific_parts.each do |p| %>
    <%= render "student/questions/sidebar_part",
        part: p,
        current_part: current_part,
        current_question: current_question,
        session_record: session_record,
        subject: subject,
        access_code: access_code %>
  <% end %>

  <hr class="border-slate-700 my-3">

  <%= link_to student_settings_path(access_code: access_code),
      class: "flex items-center gap-1.5 text-slate-400 text-xs no-underline px-2 py-1.5 rounded-lg hover:text-slate-200 hover:bg-slate-800 transition-colors" do %>
    <span>⚙</span>
    <span>Réglages</span>
  <% end %>
</div>

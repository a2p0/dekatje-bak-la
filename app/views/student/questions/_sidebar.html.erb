<%# Sidebar content — documents first, then parts/questions %>
<div class="p-4">

  <%# Documents (DT, DR) — at the top %>
  <% has_docs = subject.dt_file.attached? || subject.dr_vierge_file.attached? %>
  <% if has_docs %>
    <p class="text-slate-500 text-[10px] uppercase tracking-wide mb-2">Documents</p>
    <% if subject.dt_file.attached? %>
      <%= link_to rails_blob_path(subject.dt_file, disposition: "inline"),
          target: "_blank",
          class: "flex items-center gap-1.5 text-blue-400 text-xs my-1 no-underline hover:text-blue-300 transition-colors" do %>
        <%= render(BadgeComponent.new(color: :blue, label: "DT")) %>
        <span>Documents Techniques</span>
      <% end %>
    <% end %>
    <% if subject.dr_vierge_file.attached? %>
      <%= link_to rails_blob_path(subject.dr_vierge_file, disposition: "attachment"),
          class: "flex items-center gap-1.5 text-amber-400 text-xs my-1 no-underline hover:text-amber-300 transition-colors" do %>
        <%= render(BadgeComponent.new(color: :amber, label: "DR")) %>
        <span>DR vierge</span>
      <% end %>
    <% end %>
    <% if session_record.answered?(current_question.id) %>
      <% if subject.dr_corrige_file.attached? %>
        <%= link_to rails_blob_path(subject.dr_corrige_file, disposition: "inline"),
            target: "_blank",
            class: "flex items-center gap-1.5 text-emerald-400 text-xs my-1 no-underline hover:text-emerald-300 transition-colors" do %>
          <%= render(BadgeComponent.new(color: :emerald, label: "DR")) %>
          <span>DR corrigé</span>
        <% end %>
      <% end %>
      <% if subject.questions_corrigees_file.attached? %>
        <%= link_to rails_blob_path(subject.questions_corrigees_file, disposition: "inline"),
            target: "_blank",
            class: "flex items-center gap-1.5 text-blue-400 text-xs my-1 no-underline hover:text-blue-300 transition-colors" do %>
          <span>Questions corrigées</span>
        <% end %>
      <% end %>
    <% end %>
    <hr class="border-slate-700 my-3">
  <% end %>

  <%# All parts in order — active part shows questions %>
  <% parts.order(:position).each do |p| %>
    <% is_active = p == current_part %>
    <% part_questions = p.questions.kept.order(:position) %>
    <% part_answered = part_questions.count { |q| session_record.answered?(q.id) } %>

    <% if is_active %>
      <%# Active part — highlighted label + questions below %>
      <p class="text-indigo-400 text-[10px] uppercase tracking-wide mb-1 mt-2 font-semibold px-2">
        Partie <%= p.number %>
        <span class="text-slate-500 font-normal">(<%= part_answered %>/<%= part_questions.size %>)</span>
      </p>
      <% part_questions.each do |q| %>
        <% answered = session_record.answered?(q.id) %>
        <% is_current = q == current_question %>
        <% doc_refs = q.answer&.data_hints&.select { |h| h["source"].to_s.match?(/\ADT|DR/i) }&.map { |h| h["source"] }&.uniq || [] %>
        <%= link_to student_question_path(access_code: access_code, subject_id: subject.id, id: q.id),
            class: "flex items-center gap-1.5 px-2 py-1.5 my-0.5 rounded text-xs no-underline transition-colors #{is_current ? 'bg-indigo-500/20 text-white' : 'text-slate-400 hover:bg-slate-800 hover:text-slate-200'}",
            data: { action: "click->sidebar#close" } do %>
          <% if answered %>
            <span class="text-emerald-400 text-[10px]">✓</span>
          <% elsif is_current %>
            <span class="text-indigo-400 text-[10px]">◉</span>
          <% else %>
            <span class="text-slate-600 text-[10px]">○</span>
          <% end %>
          <span>Q<%= q.number %></span>
          <% doc_refs.each do |ref| %>
            <span class="text-[9px] px-1 py-0.5 rounded bg-<%= ref.start_with?("DT") ? "blue" : "amber" %>-500/15 text-<%= ref.start_with?("DT") ? "blue" : "amber" %>-400"><%= ref %></span>
          <% end %>
          <span class="text-slate-600 text-[10px] ml-auto"><%= q.points %> pts</span>
        <% end %>
      <% end %>
    <% else %>
      <%# Other part — just a clickable label %>
      <%= link_to student_subject_path(access_code: access_code, id: subject.id, part_id: p.id),
          class: "flex items-center justify-between px-2 py-1.5 mt-2 my-0.5 rounded text-xs text-slate-400 no-underline hover:bg-slate-800 hover:text-slate-200 transition-colors",
          data: { action: "click->sidebar#close" } do %>
        <span>Partie <%= p.number %></span>
        <span class="text-slate-600 text-[10px]"><%= part_answered %>/<%= part_questions.size %></span>
      <% end %>
    <% end %>
  <% end %>

  <hr class="border-slate-700 my-3">

  <%# Settings link %>
  <%= link_to student_settings_path(access_code: access_code),
      class: "flex items-center gap-1.5 text-slate-500 text-xs no-underline px-2 py-1.5 rounded hover:text-slate-300 hover:bg-slate-800 transition-colors" do %>
    <span>⚙</span>
    <span>Réglages</span>
  <% end %>

</div>

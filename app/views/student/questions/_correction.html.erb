<div class="mt-4">

  <%# Data hints (at the top — "Où trouver les données ?") %>
  <% if question.answer&.data_hints.present? %>
    <div class="bg-white/80 dark:bg-slate-900/60 rounded-2xl px-4 py-3.5 mb-3 border border-slate-200 dark:border-amber-500/20 shadow-sm">
      <p class="text-amber-700 dark:text-amber-400 font-semibold text-sm mb-2">Où trouver les données ?</p>
      <% question.answer.data_hints.each do |hint| %>
        <div class="flex items-baseline gap-2 mb-1.5">
          <%= render(BadgeComponent.new(color: hint_badge_color(hint["source"]), label: hint_source_label(hint["source"]))) %>
          <span class="text-slate-700 dark:text-slate-300 text-sm"><%= hint["location"] %></span>
        </div>
      <% end %>
    </div>
  <% end %>

  <%# Correction %>
  <div class="border-l-4 border-emerald-500 bg-emerald-50 dark:bg-emerald-500/10 rounded-r-2xl px-4 py-3.5 mb-3 dark:shadow-[0_0_15px_rgba(16,185,129,0.05)]">
    <p class="text-emerald-700 dark:text-emerald-400 font-semibold text-sm mb-2 uppercase tracking-wide">✓ Correction</p>
    <p class="text-slate-800 dark:text-slate-200 text-sm leading-relaxed"><%= question.answer&.correction_text %></p>
  </div>

  <%# Explication %>
  <% if question.answer&.explanation_text.present? %>
    <div class="bg-white/80 dark:bg-slate-900/60 rounded-2xl px-4 py-3.5 mb-3 border border-slate-200 dark:border-indigo-500/15 shadow-sm dark:shadow-[0_0_15px_rgba(99,102,241,0.05)]">
      <p class="text-blue-600 dark:text-blue-400 font-semibold text-sm mb-2">Explication</p>
      <p class="text-slate-700 dark:text-slate-300 text-sm leading-relaxed"><%= question.answer.explanation_text %></p>
    </div>
  <% end %>

  <%# Key concepts %>
  <% if question.answer&.key_concepts.present? %>
    <div class="bg-white/80 dark:bg-slate-900/60 rounded-2xl px-4 py-3.5 mb-3 border border-slate-200 dark:border-indigo-500/15 shadow-sm">
      <p class="text-indigo-600 dark:text-violet-400 font-semibold text-sm mb-2">Concepts clés</p>
      <div class="flex flex-wrap gap-1.5">
        <% question.answer.key_concepts.each do |concept| %>
          <%= render(BadgeComponent.new(color: :indigo, label: concept)) %>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# Documents correction %>
  <% if subject.dr_corrige_file.attached? || subject.questions_corrigees_file.attached? %>
    <div class="border border-slate-200 dark:border-indigo-500/15 rounded-2xl px-4 py-3.5 mb-3 bg-white/80 dark:bg-slate-900/60">
      <p class="text-slate-600 dark:text-slate-400 font-semibold text-sm mb-2">Documents correction</p>
      <% if subject.dr_corrige_file.attached? %>
        <%= link_to "DR corrigé ↗",
            rails_blob_path(subject.dr_corrige_file, disposition: "inline"),
            target: "_blank",
            class: "block text-blue-600 dark:text-blue-400 text-sm my-0.5 no-underline hover:text-blue-700 dark:hover:text-blue-300 transition-colors" %>
      <% end %>
      <% if subject.questions_corrigees_file.attached? %>
        <%= link_to "Questions corrigées ↗",
            rails_blob_path(subject.questions_corrigees_file, disposition: "inline"),
            target: "_blank",
            class: "block text-blue-600 dark:text-blue-400 text-sm my-0.5 no-underline hover:text-blue-700 dark:hover:text-blue-300 transition-colors" %>
      <% end %>
    </div>
  <% end %>

  <%# Expliquer la correction (tutored mode only) %>
  <% if defined?(session_record) && session_record&.tutored? %>
    <div class="text-center mt-3">
      <button type="button"
              class="text-indigo-500 dark:text-indigo-400 text-sm underline underline-offset-2 cursor-pointer hover:text-indigo-600 dark:hover:text-indigo-300"
              data-action="click->chat#openWithMessage"
              data-chat-message-param="Peux-tu m'expliquer cette correction ?">
        Expliquer la correction
      </button>
    </div>
  <% end %>

</div>

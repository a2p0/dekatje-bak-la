<%# app/views/student/questions/_chat_drawer.html.erb %>

<%# Backdrop %>
<div data-chat-target="backdrop"
     data-action="click->chat#close"
     class="hidden fixed inset-0 bg-black/50 z-40">
</div>

<%# Drawer panel %>
<div data-chat-target="drawer"
     class="fixed top-0 right-0 bottom-0 w-full lg:w-[400px] bg-white dark:bg-slate-900 border-l border-slate-200 dark:border-slate-700 z-50 translate-x-full transition-transform duration-200 ease-in-out flex flex-col">

  <%# Header %>
  <div class="flex items-center justify-between px-4 py-3 border-b border-slate-200 dark:border-slate-700 shrink-0">
    <span class="text-sm font-semibold text-slate-800 dark:text-slate-200">Tutorat IA</span>
    <button data-action="click->chat#close"
            class="p-1 text-slate-400 hover:text-slate-600 dark:hover:text-slate-200 transition-colors cursor-pointer bg-transparent border-none text-lg leading-none">
      ✕
    </button>
  </div>

  <%# Messages area %>
  <div data-chat-target="messages"
       class="flex-1 overflow-y-auto p-4 flex flex-col gap-3">
    <% if local_assigns[:conversation] && conversation&.messages&.any? %>
      <% conversation.messages.each do |msg| %>
        <% if msg["role"] == "user" %>
          <div class="self-end bg-indigo-500 text-white px-3 py-2 rounded-xl rounded-br-sm max-w-[85%] text-sm leading-relaxed break-words">
            <%= msg["content"] %>
          </div>
        <% else %>
          <div class="self-start bg-slate-100 dark:bg-slate-800 text-slate-800 dark:text-slate-200 px-3 py-2 rounded-xl rounded-bl-sm max-w-[85%] text-sm leading-relaxed break-words">
            <%= msg["content"] %>
          </div>
        <% end %>
      <% end %>
    <% else %>
      <div class="text-slate-400 dark:text-slate-500 text-sm text-center mt-10">
        Posez votre question pour commencer le tutorat.
      </div>
    <% end %>
  </div>

  <%# Streaming response placeholder %>
  <div data-chat-target="streaming"
       class="hidden self-start bg-slate-100 dark:bg-slate-800 text-slate-800 dark:text-slate-200 px-3 py-2 rounded-xl rounded-bl-sm max-w-[85%] text-sm leading-relaxed mx-4 mb-3 break-words">
  </div>

  <%# Error area %>
  <div data-chat-target="error"
       class="hidden mx-4 mb-2 px-3 py-2 bg-red-950 text-red-300 rounded-lg text-xs">
  </div>

  <%# Input area %>
  <div class="px-4 py-3 border-t border-slate-200 dark:border-slate-700 shrink-0">
    <div class="flex gap-2">
      <input data-chat-target="input"
             data-action="keydown.enter->chat#send"
             type="text"
             placeholder="Ecrivez votre question..."
             class="flex-1 px-3 py-2 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-sm text-slate-800 dark:text-slate-200 placeholder-slate-400 dark:placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-indigo-500"
             autocomplete="off">
      <button data-chat-target="sendButton"
              data-action="click->chat#send"
              class="px-4 py-2 bg-indigo-500 hover:bg-indigo-600 text-white rounded-lg text-sm font-medium transition-colors cursor-pointer whitespace-nowrap border-none">
        Envoyer
      </button>
    </div>
  </div>
</div>

<div class="bg-white/80 dark:bg-slate-900/60 border border-slate-200 dark:border-indigo-500/15 rounded-2xl p-6 mb-8 shadow-sm dark:shadow-[0_0_15px_rgba(99,102,241,0.05)]">
  <h2 class="text-xs font-semibold text-indigo-600 dark:text-indigo-400 uppercase tracking-wider mb-3">Mise en situation — Partie specifique</h2>
  <div class="text-sm text-slate-700 dark:text-slate-300 leading-relaxed whitespace-pre-line"><%= subject.specific_presentation %></div>
</div>

<div class="text-center">
  <% if first_question %>
    <%= render(ButtonComponent.new(
      variant: :gradient,
      size: :lg,
      pill: true,
      href: student_question_path(access_code: access_code, subject_id: subject.id, id: first_question.id, mark_specific_seen: true)
    )) { "Commencer" } %>
  <% end %>
</div>

<div class="bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg p-6 mb-8">
  <h2 class="text-sm font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-3">Mise en situation — Partie specifique</h2>
  <div class="text-sm text-slate-700 dark:text-slate-300 leading-relaxed whitespace-pre-line"><%= subject.specific_presentation %></div>
</div>

<div class="text-center">
  <% if first_question %>
    <%= link_to student_question_path(access_code: access_code, subject_id: subject.id, id: first_question.id, mark_specific_seen: true),
        class: "inline-flex items-center px-8 py-3 bg-emerald-600 text-white rounded-full text-sm font-semibold no-underline hover:bg-emerald-700 transition-colors" do %>
      Commencer
    <% end %>
  <% end %>
</div>

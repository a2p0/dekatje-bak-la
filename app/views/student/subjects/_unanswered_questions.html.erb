<div class="bg-white/80 dark:bg-slate-900/60 border border-slate-200 dark:border-indigo-500/15 rounded-2xl p-6 mb-8 shadow-sm dark:shadow-[0_0_15px_rgba(99,102,241,0.05)]">
  <h2 class="text-lg font-semibold text-slate-800 dark:text-slate-100 mb-1">Questions non repondues</h2>
  <p class="text-sm text-slate-600 dark:text-slate-400 mb-4">Il vous reste <%= unanswered_questions.size %> question<%= unanswered_questions.size > 1 ? "s" : "" %> a revoir.</p>

  <div class="space-y-2">
    <% unanswered_questions.each do |question| %>
      <div class="flex items-center justify-between py-2 border-b border-slate-100 dark:border-slate-700/50 last:border-0">
        <div class="min-w-0">
          <span class="text-sm font-medium text-slate-800 dark:text-slate-200">Question <%= question.number %></span>
          <span class="text-sm text-slate-600 dark:text-slate-400 ml-2">— <%= truncate(question.label, length: 80) %></span>
        </div>
        <%= link_to "Revenir a cette question",
            student_question_path(access_code: access_code, subject_id: subject.id, id: question.id, from: "review"),
            class: "text-xs text-indigo-600 dark:text-indigo-400 no-underline hover:text-indigo-700 dark:hover:text-indigo-300 whitespace-nowrap ml-3" %>
      </div>
    <% end %>
  </div>
</div>

<div class="text-center">
  <%= button_to "Terminer le sujet",
      student_subject_completion_path(access_code: access_code, subject_id: subject.id),
      method: :post,
      class: "inline-flex items-center px-8 py-3 bg-gradient-to-br from-indigo-500 to-violet-500 text-white rounded-full text-sm font-semibold border-0 cursor-pointer hover:from-indigo-600 hover:to-violet-600 transition-all shadow-[0_0_16px_rgba(99,102,241,0.3)]" %>
</div>

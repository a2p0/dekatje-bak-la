<div class="max-w-3xl mx-auto px-4 py-8">
  <%# Breadcrumb %>
  <div class="mb-4">
    <%= render(BreadcrumbComponent.new(items: [
      { label: "Mes sujets", href: student_root_path(access_code: params[:access_code]) },
      { label: @subject.title }
    ])) %>
  </div>

  <%# Subject title %>
  <h1 class="text-2xl sm:text-3xl font-bold text-slate-800 dark:text-slate-100 mb-3"><%= @subject.title %></h1>
  <div class="flex flex-wrap gap-1.5 mb-6">
    <%= render(BadgeComponent.new(color: :indigo, label: @subject.specialty&.upcase || "—")) %>
    <%= render(BadgeComponent.new(color: :emerald, label: @subject.year.to_s)) %>
    <% if @subject.region.present? %>
      <%= render(BadgeComponent.new(color: :slate, label: @subject.region)) %>
    <% end %>
  </div>

  <% if @session_record.requires_scope_selection? && !@session_record.scope_selected? %>
    <%# === SCOPE SELECTION SCREEN === %>
    <%= render "student/subjects/scope_selection",
        subject: @subject,
        session_record: @session_record,
        access_code: params[:access_code] %>

  <% elsif @show_completion %>
    <%# === COMPLETION PAGE "BRAVO !!" === %>
    <%= render "student/subjects/completion", access_code: params[:access_code] %>

  <% elsif @unanswered_questions %>
    <%# === UNANSWERED QUESTIONS PAGE === %>
    <%= render "student/subjects/unanswered_questions",
        unanswered_questions: @unanswered_questions,
        subject: @subject,
        session_record: @session_record,
        access_code: params[:access_code] %>

  <% elsif @show_specific_presentation %>
    <%# === SPECIFIC PRESENTATION === %>
    <%= render "student/subjects/specific_presentation",
        subject: @subject,
        first_question: @first_specific_question,
        session_record: @session_record,
        access_code: params[:access_code] %>

  <% else %>
    <%# === MISE EN SITUATION + PARTS OVERVIEW (standard flow) === %>

    <%# Tutor activation banner — only for autonomous students with an API key %>
    <% if @session_record.autonomous? && current_student.api_key.present? %>
      <%= render "student/tutor/tutor_banner",
                 subject: @subject,
                 access_code: params[:access_code] %>
    <% end %>

    <%# Auto-open drawer if tutor active but welcome not yet sent (page reload case) %>
    <% if @auto_open_drawer %>
      <div data-controller="auto-dispatch"
           data-auto-dispatch-event-value="tutor:drawer-open"
           class="hidden"></div>
    <% end %>

    <%# Scope change link (for new-format subjects with scope already selected) %>
    <% if @session_record.requires_scope_selection? && @session_record.scope_selected? %>
      <div class="bg-indigo-50 dark:bg-indigo-500/10 border border-indigo-200 dark:border-indigo-500/20 rounded-xl px-4 py-3 mb-6 flex items-center justify-between">
        <div class="text-sm text-indigo-700 dark:text-indigo-300">
          <span class="font-medium">Perimetre :</span>
          <%= scope_label(@session_record, @subject) %>
        </div>
        <button type="button"
                class="text-xs text-indigo-600 dark:text-indigo-400 underline underline-offset-2 hover:text-indigo-800 dark:hover:text-indigo-200 cursor-pointer"
                aria-expanded="false"
                aria-controls="scope-selector"
                onclick="var el = document.getElementById('scope-selector'); el.classList.toggle('hidden'); this.setAttribute('aria-expanded', !el.classList.contains('hidden'));">
          Changer de perimetre
        </button>
      </div>
      <div id="scope-selector" class="hidden mb-6">
        <%= render "student/subjects/scope_selection",
            subject: @subject,
            session_record: @session_record,
            access_code: params[:access_code] %>
      </div>
    <% end %>

    <%# Relecture mode banner %>
    <% if @relecture_mode %>
      <div class="bg-emerald-50 dark:bg-emerald-500/10 border border-emerald-200 dark:border-emerald-500/20 rounded-xl px-4 py-3 mb-6">
        <p class="text-sm text-emerald-700 dark:text-emerald-400 font-medium">Mode relecture — Naviguez librement dans les questions pour revoir les corrections.</p>
      </div>
    <% end %>

    <%# Mise en situation — full text from PDF (only on first visit, not relecture) %>
    <% unless @relecture_mode %>
      <div class="bg-white/80 dark:bg-slate-900/60 border border-slate-200 dark:border-indigo-500/15 rounded-2xl p-6 mb-6 shadow-sm dark:shadow-[0_0_15px_rgba(99,102,241,0.05)]">
        <h2 class="text-xs font-semibold text-indigo-600 dark:text-indigo-400 uppercase tracking-wider mb-3">Mise en situation</h2>
        <div class="text-sm text-slate-700 dark:text-slate-300 leading-relaxed whitespace-pre-line"><%= @subject.common_presentation %></div>
      </div>
    <% end %>

    <%# Parts overview with grouping %>
    <div class="bg-white/80 dark:bg-slate-900/60 border border-slate-200 dark:border-indigo-500/15 rounded-2xl p-6 mb-8 shadow-sm dark:shadow-[0_0_15px_rgba(99,102,241,0.05)]">
      <h2 class="text-xs font-semibold text-indigo-600 dark:text-indigo-400 uppercase tracking-wider mb-3">Parties du sujet</h2>

      <% common_parts_list = common_parts(@parts) %>
      <% specific_parts_list = specific_parts(@parts) %>
      <% show_section_headers = common_parts_list.any? && specific_parts_list.any? %>

      <div class="space-y-2">
        <% if show_section_headers && common_parts_list.any? %>
          <div class="pt-2 pb-1">
            <span class="text-xs font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest">Partie commune</span>
          </div>
        <% end %>

        <% common_parts_list.each do |part| %>
          <%= render "student/subjects/part_row", part: part, session_record: @session_record %>
        <% end %>

        <% if show_section_headers && specific_parts_list.any? %>
          <div class="pt-4 pb-1">
            <span class="text-xs font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest">Partie specifique</span>
          </div>
        <% end %>

        <% specific_parts_list.each do |part| %>
          <%= render "student/subjects/part_row", part: part, session_record: @session_record %>
        <% end %>
      </div>
    </div>

    <%# Start / Continue button at the bottom %>
    <div class="text-center">
      <%
        first_q = @first_question
        incomplete_part = @parts&.find { |p| !@session_record.part_completed?(p.id) }
        incomplete_part ||= @parts&.first
        first_q ||= incomplete_part&.questions&.kept&.order(:position)&.first

        # Route through subject#show if specific presentation needs to be shown
        needs_specific_presentation = incomplete_part&.section_type == "specific" &&
          @subject.specific_presentation.present? &&
          !@session_record.specific_presentation_seen?
      %>
      <% if needs_specific_presentation %>
        <%= render(ButtonComponent.new(
          variant: :gradient,
          size: :lg,
          pill: true,
          href: student_subject_path(access_code: params[:access_code], id: @subject.id, start: true)
        )) { "Commencer" } %>
      <% elsif first_q %>
        <%= render(ButtonComponent.new(
          variant: :gradient,
          size: :lg,
          pill: true,
          href: student_question_path(access_code: params[:access_code], subject_id: @subject.id, id: first_q.id)
        )) { "Commencer" } %>
      <% end %>
    </div>
  <% end %>
</div>

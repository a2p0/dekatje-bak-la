<%= render(NavBarComponent.new) do |nav|
  nav.with_brand { "DekatjeBakLa" }
  nav.with_actions do
    render(ThemeToggleComponent.new) +
    link_to("← Mes sujets", student_root_path(access_code: params[:access_code]),
      class: "text-sm text-slate-500 dark:text-slate-400 hover:text-slate-700 dark:hover:text-slate-200")
  end
end %>

<main class="max-w-3xl mx-auto px-4 py-8">
  <%# Subject title %>
  <h1 class="text-2xl font-bold text-slate-800 dark:text-slate-100 mb-2"><%= @subject.title %></h1>
  <div class="flex flex-wrap gap-1.5 mb-6">
    <%= render(BadgeComponent.new(color: :indigo, label: @subject.specialty&.upcase || "—")) %>
    <%= render(BadgeComponent.new(color: :emerald, label: @subject.year.to_s)) %>
    <% if @subject.region.present? %>
      <%= render(BadgeComponent.new(color: :slate, label: @subject.region)) %>
    <% end %>
  </div>

  <% if @session_record.requires_scope_selection? && !@session_record.scope_selected? %>
    <%# === SCOPE SELECTION SCREEN === %>
    <%= render "student/subjects/scope_selection",
        subject: @subject,
        session_record: @session_record,
        access_code: params[:access_code] %>

  <% elsif @show_completion %>
    <%# === COMPLETION PAGE "BRAVO !!" === %>
    <%= render "student/subjects/completion", access_code: params[:access_code] %>

  <% elsif @unanswered_questions %>
    <%# === UNANSWERED QUESTIONS PAGE === %>
    <%= render "student/subjects/unanswered_questions",
        unanswered_questions: @unanswered_questions,
        subject: @subject,
        session_record: @session_record,
        access_code: params[:access_code] %>

  <% elsif @show_specific_presentation %>
    <%# === SPECIFIC PRESENTATION === %>
    <%= render "student/subjects/specific_presentation",
        subject: @subject,
        first_question: @first_specific_question,
        session_record: @session_record,
        access_code: params[:access_code] %>

  <% else %>
    <%# === MISE EN SITUATION + PARTS OVERVIEW (standard flow) === %>

    <%# Tutor activation banner — only for autonomous students with an API key %>
    <% if @session_record.autonomous? && current_student.api_key.present? %>
      <%= render "student/tutor/tutor_banner",
                 subject: @subject,
                 access_code: params[:access_code] %>
    <% end %>

    <%# Scope change link (for new-format subjects with scope already selected) %>
    <% if @session_record.requires_scope_selection? && @session_record.scope_selected? %>
      <div class="bg-indigo-50 dark:bg-indigo-900/20 border border-indigo-200 dark:border-indigo-800 rounded-lg px-4 py-3 mb-6 flex items-center justify-between">
        <div class="text-sm text-indigo-700 dark:text-indigo-300">
          <span class="font-medium">Perimetre :</span>
          <%= scope_label(@session_record, @subject) %>
        </div>
        <button type="button"
                class="text-xs text-indigo-600 dark:text-indigo-400 underline underline-offset-2 hover:text-indigo-800 dark:hover:text-indigo-200 cursor-pointer"
                onclick="document.getElementById('scope-selector').classList.toggle('hidden')">
          Changer de perimetre
        </button>
      </div>
      <div id="scope-selector" class="hidden mb-6">
        <%= render "student/subjects/scope_selection",
            subject: @subject,
            session_record: @session_record,
            access_code: params[:access_code] %>
      </div>
    <% end %>

    <%# Relecture mode banner %>
    <% if @relecture_mode %>
      <div class="bg-emerald-50 dark:bg-emerald-900/20 border border-emerald-200 dark:border-emerald-800 rounded-lg px-4 py-3 mb-6">
        <p class="text-sm text-emerald-700 dark:text-emerald-300 font-medium">Mode relecture — Naviguez librement dans les questions pour revoir les corrections.</p>
      </div>
    <% end %>

    <%# Mise en situation — full text from PDF (only on first visit, not relecture) %>
    <% unless @relecture_mode %>
      <div class="bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg p-6 mb-6">
        <h2 class="text-sm font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-3">Mise en situation</h2>
        <div class="text-sm text-slate-700 dark:text-slate-300 leading-relaxed whitespace-pre-line"><%= @subject.common_presentation %></div>
      </div>
    <% end %>

    <%# Parts overview with grouping %>
    <div class="bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg p-6 mb-8">
      <h2 class="text-sm font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-3">Parties du sujet</h2>

      <% common_parts = @parts.select { |p| p.section_type == "common" } %>
      <% specific_parts = @parts.select { |p| p.section_type == "specific" } %>
      <% show_section_headers = common_parts.any? && specific_parts.any? %>

      <div class="space-y-2">
        <% if show_section_headers && common_parts.any? %>
          <div class="pt-2 pb-1">
            <span class="text-xs font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest">Partie commune</span>
          </div>
        <% end %>

        <% common_parts.each do |part| %>
          <%= render "student/subjects/part_row", part: part, session_record: @session_record %>
        <% end %>

        <% if show_section_headers && specific_parts.any? %>
          <div class="pt-4 pb-1">
            <span class="text-xs font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest">Partie specifique</span>
          </div>
        <% end %>

        <% specific_parts.each do |part| %>
          <%= render "student/subjects/part_row", part: part, session_record: @session_record %>
        <% end %>
      </div>
    </div>

    <%# Start / Continue button at the bottom %>
    <div class="text-center">
      <%
        first_q = @first_question
        unless first_q
          incomplete_part = @parts&.find { |p| !@session_record.part_completed?(p.id) } || @parts&.first
          first_q = incomplete_part&.questions&.kept&.order(:position)&.first
        end
      %>
      <% if first_q %>
        <%= link_to student_question_path(access_code: params[:access_code], subject_id: @subject.id, id: first_q.id),
            class: "inline-flex items-center px-8 py-3 bg-emerald-600 text-white rounded-full text-sm font-semibold no-underline hover:bg-emerald-700 transition-colors" do %>
          Commencer
        <% end %>
      <% end %>
    </div>
  <% end %>
</main>

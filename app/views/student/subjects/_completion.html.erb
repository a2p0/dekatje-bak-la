<div class="text-center py-16 relative">
  <%# Confetti trigger (respects prefers-reduced-motion) %>
  <%= render(ConfettiComponent.new) %>

  <div class="text-6xl mb-6" aria-hidden="true">🎉</div>
  <h2 class="text-3xl sm:text-5xl font-bold mb-4">
    <span class="bg-gradient-to-br from-indigo-500 via-violet-500 to-emerald-500 bg-clip-text text-transparent">Bravo !!</span>
  </h2>
  <p class="text-slate-700 dark:text-slate-300 mb-8 text-base">Vous avez termine ce sujet.</p>
  <%= render(ButtonComponent.new(
    variant: :gradient,
    size: :lg,
    pill: true,
    href: student_root_path(access_code: access_code)
  )) { "Revenir aux sujets" } %>
</div>

<div class="flex items-start justify-between py-3 border-b border-slate-100 dark:border-slate-700/50 last:border-0"
     data-part-id="<%= part.id %>"
     data-part-completed="<%= session_record.part_completed?(part.id) %>">
  <div class="flex-1 min-w-0">
    <div class="flex items-center gap-2 flex-wrap">
      <span class="text-sm font-semibold text-slate-800 dark:text-slate-200">Partie <%= part.number %></span>
      <span class="text-sm text-slate-600 dark:text-slate-400">— <%= part.title %></span>
      <% if session_record.part_completed?(part.id) %>
        <%= render(BadgeComponent.new(color: :emerald, label: "Terminé ✓")) %>
      <% end %>
    </div>
    <% if part.objective_text.present? %>
      <p class="text-xs text-slate-600 dark:text-slate-500 mt-1"><%= part.objective_text %></p>
    <% end %>
  </div>
  <span class="text-xs text-slate-600 dark:text-slate-500 whitespace-nowrap ml-3"><%= part.questions.kept.count %> questions</span>
</div>

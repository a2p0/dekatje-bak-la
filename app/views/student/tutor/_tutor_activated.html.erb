<div id="tutor-activation-banner"
     class="bg-emerald-50 dark:bg-emerald-900/20 border border-emerald-200 dark:border-emerald-500/30 rounded-lg p-4 mb-6">
  <div class="flex items-center gap-3">
    <span class="text-emerald-600 dark:text-emerald-400 text-lg">✓</span>
    <div>
      <p class="text-sm font-semibold text-emerald-800 dark:text-emerald-200">Mode tuteur activé</p>
      <p class="text-xs text-emerald-700 dark:text-emerald-300 mt-0.5">
        Le tuteur vous accompagnera dès la première question.
      </p>
    </div>
    <%
      first_question = subject.parts.order(:position).first&.questions&.kept&.order(:position)&.first
    %>
    <% if first_question %>
      <%= link_to "Commencer",
          student_question_path(access_code: access_code, subject_id: subject.id, id: first_question.id),
          class: "ml-auto inline-flex items-center px-4 py-2 bg-emerald-600 text-white text-sm font-semibold rounded-lg hover:bg-emerald-700 transition-colors" %>
    <% end %>
  </div>
</div>

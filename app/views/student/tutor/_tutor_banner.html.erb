<div id="tutor-activation-banner"
     class="rounded-lg p-4 mb-6 flex items-center gap-3
            <%= tutor_status == :active    ? 'bg-emerald-50 dark:bg-emerald-900/20 border border-emerald-200 dark:border-emerald-500/30' :
                tutor_status == :available ? 'bg-indigo-50 dark:bg-indigo-900/20 border border-indigo-200 dark:border-indigo-500/30' :
                                             'bg-slate-50 dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700' %>">

  <% if tutor_status == :active %>
    <span class="text-emerald-500 dark:text-emerald-400 text-base">●</span>
    <p class="text-sm font-medium text-emerald-800 dark:text-emerald-200">Tuteur actif</p>
  <% elsif tutor_status == :available %>
    <span class="text-indigo-400 dark:text-indigo-300 text-base">◌</span>
    <p class="text-sm font-medium text-indigo-800 dark:text-indigo-200">
      Tuteur disponible
      <span class="font-normal text-indigo-600 dark:text-indigo-400">— activez-le depuis une question</span>
    </p>
  <% else %>
    <span class="text-slate-400 text-base">○</span>
    <p class="text-sm font-medium text-slate-600 dark:text-slate-400">
      Tuteur indisponible
      <span class="font-normal">—</span>
      <%= link_to "Paramétrer", student_settings_path(access_code: access_code),
                  class: "underline underline-offset-2 hover:text-slate-800 dark:hover:text-slate-200" %>
    </p>
  <% end %>
</div>

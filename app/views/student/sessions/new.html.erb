<div class="min-h-screen relative overflow-hidden bg-gradient-to-b from-slate-50 to-white dark:from-slate-950 dark:to-slate-900 flex items-center justify-center px-4">
  <%# Subtle radial glow %>
  <div aria-hidden="true" class="pointer-events-none absolute -top-32 left-1/2 -translate-x-1/2 w-[500px] h-[300px] bg-[radial-gradient(ellipse,rgba(99,102,241,0.18),transparent_70%)]"></div>

  <%# Theme toggle %>
  <div class="absolute top-4 right-4 sm:top-6 sm:right-6 z-20">
    <%= render(ThemeToggleComponent.new) %>
  </div>

  <div class="relative z-10 max-w-sm w-full">
    <%# Brand %>
    <div class="text-center mb-6">
      <p class="text-base font-bold bg-gradient-to-br from-indigo-500 to-violet-500 bg-clip-text text-transparent">DekatjeBakLa</p>
    </div>

    <%# Login card %>
    <div class="bg-white/70 dark:bg-slate-900/60 border border-slate-200 dark:border-indigo-500/15 rounded-2xl p-6 shadow-sm dark:shadow-[0_0_25px_rgba(99,102,241,0.08)] backdrop-blur-sm">
      <div class="text-center mb-6">
        <h1 class="text-xl font-bold text-slate-800 dark:text-slate-100 mb-1"><%= @classroom.name %></h1>
        <p class="text-sm text-slate-600 dark:text-slate-400">Connecte-toi pour accéder aux sujets</p>
      </div>

      <%= form_tag student_session_path(access_code: params[:access_code]), method: :post do %>
        <div class="space-y-4">
          <div>
            <label for="username" class="block text-xs font-semibold text-slate-700 dark:text-slate-400 mb-1.5 uppercase tracking-wide">Identifiant</label>
            <%= text_field_tag :username, nil,
                id: "username",
                autocomplete: "username",
                class: "w-full px-4 py-3 bg-white dark:bg-slate-900/80 border border-slate-200 dark:border-indigo-500/15 rounded-xl text-sm text-slate-800 dark:text-slate-200 placeholder-slate-400 dark:placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
          </div>
          <div>
            <label for="password" class="block text-xs font-semibold text-slate-700 dark:text-slate-400 mb-1.5 uppercase tracking-wide">Mot de passe</label>
            <%= password_field_tag :password, nil,
                id: "password",
                autocomplete: "current-password",
                class: "w-full px-4 py-3 bg-white dark:bg-slate-900/80 border border-slate-200 dark:border-indigo-500/15 rounded-xl text-sm text-slate-800 dark:text-slate-200 placeholder-slate-400 dark:placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
          </div>
          <div class="pt-2">
            <%= render(ButtonComponent.new(variant: :gradient, type: "submit", class: "w-full justify-center")) { "Se connecter" } %>
          </div>
        </div>
      <% end %>
    </div>

    <div class="text-center mt-6">
      <%= link_to "← Retour", root_path, class: "text-sm text-slate-600 dark:text-slate-400 hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors" %>
    </div>
  </div>
</div>

<h1>Mes classes</h1>

<%= link_to "Nouvelle classe", new_teacher_classroom_path %>

<% if @classrooms.empty? %>
  <p>Vous n'avez pas encore de classe.</p>
<% else %>
  <ul>
    <% @classrooms.each do |classroom| %>
      <li>
        <%= link_to classroom.name, teacher_classroom_path(classroom) %>
        — <%= classroom.school_year %>
        (<%= classroom.students.count %> élèves)
      </li>
    <% end %>
  </ul>
<% end %>

<h2>Sujets récents</h2>

<%= link_to "Nouveau sujet", new_teacher_subject_path %> |
<%= link_to "Voir tous les sujets", teacher_subjects_path %>

<% if @recent_subjects.empty? %>
  <p>Aucun sujet pour l'instant.</p>
<% else %>
  <ul>
    <% @recent_subjects.each do |subject| %>
      <li>
        <%= link_to subject.title, teacher_subject_path(subject) %>
        — <%= subject.specialty %> — <strong><%= subject.status %></strong>
      </li>
    <% end %>
  </ul>
<% end %>

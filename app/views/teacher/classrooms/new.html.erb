<%# Nouvelle classe — new %>
<div class="max-w-md mx-auto">
  <h1 class="text-2xl font-bold text-slate-900 dark:text-white mb-6">Nouvelle classe</h1>

  <%= form_with model: [:teacher, @classroom],
                class: "space-y-4" do |f| %>
    <div>
      <%= f.label :name, "Nom de la classe",
            class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1" %>
      <%= f.text_field :name,
            required: true,
            class: "w-full px-4 py-2.5 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-sm text-slate-900 dark:text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent" %>
    </div>

    <div>
      <%= f.label :school_year, "Année scolaire",
            class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1" %>
      <%= f.text_field :school_year,
            placeholder: "2026",
            required: true,
            class: "w-full px-4 py-2.5 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-sm text-slate-900 dark:text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent" %>
    </div>

    <div>
      <%= f.label :specialty, "Spécialité",
            class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1" %>
      <%= f.text_field :specialty,
            placeholder: "SIN, ITEC, EC...",
            class: "w-full px-4 py-2.5 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-sm text-slate-900 dark:text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent" %>
    </div>

    <div class="pt-2">
      <%= render ButtonComponent.new(variant: :primary, size: :md, type: :submit) do %>
        Créer la classe
      <% end %>
    </div>
  <% end %>
</div>

<%# Nouvelle classe — new %>
<div class="max-w-md mx-auto">
  <h1 class="text-2xl font-bold text-slate-900 dark:text-white mb-6">Nouvelle classe</h1>

  <%= form_with model: [:teacher, @classroom],
                class: "space-y-4" do |f| %>
    <%= render "teacher/shared/field", f: f, field: :name, label_text: "Nom de la classe", options: { required: true } %>
    <%= render "teacher/shared/field", f: f, field: :school_year, label_text: "Année scolaire", options: { placeholder: "2026", required: true } %>
    <%= render "teacher/shared/field", f: f, field: :specialty, label_text: "Spécialité", options: { placeholder: "SIN, ITEC, EC..." } %>

    <div class="pt-2">
      <%= render ButtonComponent.new(variant: :primary, size: :md, type: :submit) do %>
        Créer la classe
      <% end %>
    </div>
  <% end %>
</div>

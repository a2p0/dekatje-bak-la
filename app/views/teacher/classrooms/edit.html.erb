<%= render BreadcrumbComponent.new(items: [
  { label: "Mes classes", href: teacher_root_path },
  { label: @classroom.name, href: teacher_classroom_path(@classroom) },
  { label: "Paramètres" }
]) %>

<div class="max-w-xl">
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-slate-900 dark:text-white mb-1">
      Paramètres — <%= @classroom.name %>
    </h1>
  </div>

  <%= form_with model: @classroom,
                url: teacher_classroom_path(@classroom),
                method: :patch do |f| %>

    <div class="bg-white/80 dark:bg-slate-900/60 border border-slate-200 dark:border-indigo-500/15 rounded-2xl p-5 mb-5 shadow-sm">
      <p class="text-xs font-semibold uppercase tracking-wider text-indigo-600 dark:text-indigo-400 mb-4">
        Mode tuteur
      </p>

      <%= render "teacher/shared/field", f: f, field: :tutor_free_mode_enabled,
            label_text: "Activer le tuteur en mode gratuit pour cette classe",
            type: :checkbox,
            hint: "Les élèves sans clé personnelle pourront utiliser le tuteur via votre clé OpenRouter." %>

      <% if @classroom.tutor_free_mode_enabled? && current_user.openrouter_api_key.blank? %>
        <div class="mt-3 flex items-start gap-2 rounded-lg bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-700 px-3 py-2">
          <span class="text-amber-500 shrink-0 mt-0.5">⚠</span>
          <p class="text-xs text-amber-700 dark:text-amber-300">
            Mode gratuit activé mais votre clé OpenRouter est manquante.
            <%= link_to "Configurez-la dans votre profil", edit_user_registration_path,
                class: "underline font-medium hover:text-amber-900 dark:hover:text-amber-100" %>
            pour que les élèves puissent utiliser le tuteur.
          </p>
        </div>
      <% end %>
    </div>

    <%= render(ButtonComponent.new(variant: :primary, size: :md, type: "submit")) { "Enregistrer" } %>
  <% end %>
</div>

<%# Détail classe — show %>
<div class="mb-6">
  <h1 class="text-2xl font-bold text-slate-900 dark:text-white mb-2"><%= @classroom.name %></h1>
  <div class="flex flex-wrap items-center gap-2">
    <% if @classroom.specialty.present? %>
      <%= render BadgeComponent.new(color: :indigo, label: @classroom.specialty) %>
    <% end %>
    <%= render BadgeComponent.new(color: :slate, label: @classroom.school_year) %>
    <span class="text-sm text-slate-500 dark:text-slate-400">
      Code d'accès :
      <code class="px-1.5 py-0.5 bg-slate-100 dark:bg-slate-700 rounded text-sm font-mono text-slate-700 dark:text-slate-200">
        <%= @classroom.access_code %>
      </code>
    </span>
  </div>
</div>

<% if @generated_credentials.present? %>
  <div id="generated-credentials"
       class="mb-6 rounded-lg border border-amber-300 bg-amber-50 dark:border-amber-700 dark:bg-amber-900/20 p-4">
    <h2 class="text-base font-semibold text-amber-800 dark:text-amber-300 mb-3">
      Identifiants générés — à noter maintenant !
    </h2>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-amber-100 dark:bg-amber-800/30">
            <th class="px-4 py-2 text-left text-xs font-medium text-amber-700 dark:text-amber-400 uppercase">Nom</th>
            <th class="px-4 py-2 text-left text-xs font-medium text-amber-700 dark:text-amber-400 uppercase">Identifiant</th>
            <th class="px-4 py-2 text-left text-xs font-medium text-amber-700 dark:text-amber-400 uppercase">Mot de passe</th>
          </tr>
        </thead>
        <tbody>
          <% @generated_credentials.each do |cred| %>
            <tr>
              <td class="px-4 py-3 border-t border-amber-200 dark:border-amber-700/50 text-slate-700 dark:text-slate-200">
                <%= cred["name"] %>
              </td>
              <td class="px-4 py-3 border-t border-amber-200 dark:border-amber-700/50 font-mono text-slate-700 dark:text-slate-200">
                <%= cred["username"] %>
              </td>
              <td class="px-4 py-3 border-t border-amber-200 dark:border-amber-700/50 font-mono text-slate-700 dark:text-slate-200">
                <%= cred["password"] %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    <div class="mt-3">
      <%= render ButtonComponent.new(
            href: teacher_classroom_export_path(@classroom, format: :pdf),
            variant: :primary, size: :sm) do %>
        Télécharger la fiche PDF
      <% end %>
    </div>
  </div>
<% end %>

<div class="flex flex-wrap items-center justify-between gap-3 mb-4">
  <h2 class="text-lg font-semibold text-slate-900 dark:text-white">
    Élèves (<%= @students.size %>)
  </h2>
  <div class="flex flex-wrap items-center gap-2">
    <%= render ButtonComponent.new(
          href: new_teacher_classroom_student_path(@classroom),
          variant: :primary, size: :sm) do %>
      Ajouter un élève
    <% end %>
    <%= render ButtonComponent.new(
          href: new_teacher_classroom_student_import_path(@classroom),
          variant: :ghost, size: :sm) do %>
      Ajout en lot
    <% end %>
    <%= render ButtonComponent.new(
          href: teacher_classroom_export_path(@classroom, format: :pdf),
          variant: :ghost, size: :sm) do %>
      Exporter fiches PDF
    <% end %>
    <%= render ButtonComponent.new(
          href: teacher_classroom_export_path(@classroom, format: :markdown),
          variant: :ghost, size: :sm) do %>
      Exporter Markdown
    <% end %>
    <%= render ButtonComponent.new(
          href: edit_teacher_classroom_path(@classroom),
          variant: :ghost, size: :sm) do %>
      Paramètres
    <% end %>
  </div>
</div>

<% if @students.empty? %>
  <p class="text-slate-500 dark:text-slate-400">Aucun élève dans cette classe.</p>
<% else %>
  <div class="overflow-x-auto rounded-lg border border-slate-200 dark:border-slate-700">
    <table id="students-table" class="w-full text-sm">
      <thead>
        <tr class="bg-slate-50 dark:bg-slate-800">
          <th class="px-4 py-2 text-left text-xs font-medium text-slate-500 dark:text-slate-400 uppercase">Nom</th>
          <th class="px-4 py-2 text-left text-xs font-medium text-slate-500 dark:text-slate-400 uppercase">Identifiant</th>
          <th class="px-4 py-2 text-left text-xs font-medium text-slate-500 dark:text-slate-400 uppercase">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @students.each do |student| %>
          <tr id="student-<%= student.id %>">
            <td class="px-4 py-3 border-t border-slate-200 dark:border-slate-700 text-slate-900 dark:text-white">
              <%= student.last_name %> <%= student.first_name %>
            </td>
            <td class="px-4 py-3 border-t border-slate-200 dark:border-slate-700 font-mono text-slate-600 dark:text-slate-300">
              <%= student.username %>
            </td>
            <td class="px-4 py-3 border-t border-slate-200 dark:border-slate-700">
              <%= button_to teacher_student_password_reset_path(student),
                    method: :post,
                    data: { confirm: "Réinitialiser le mot de passe de #{student.first_name} #{student.last_name} ?" },
                    class: "inline-flex items-center justify-center font-semibold transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 cursor-pointer border border-slate-200 dark:border-slate-700 text-slate-600 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-800 px-3 py-1.5 text-xs rounded-lg" do %>
                Réinitialiser mot de passe
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>

<div class="max-w-md mx-auto">
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-slate-900 dark:text-slate-100">
      Ajouter des élèves en masse
    </h1>
    <p class="mt-1 text-sm text-slate-500 dark:text-slate-400"><%= @classroom.name %></p>
  </div>

  <div class="bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl p-6">
    <p class="text-sm text-slate-600 dark:text-slate-400 mb-4">
      Saisissez un élève par ligne, au format : <strong class="text-slate-900 dark:text-slate-100">Prénom Nom</strong>
    </p>

    <%= form_with url: teacher_classroom_student_import_path(@classroom), method: :post do |f| %>
      <div class="space-y-4">
        <%= render "teacher/shared/field", f: f, field: :students_list, label_text: "Liste des élèves",
              type: :textarea,
              options: { rows: 15, placeholder: "Jean Dupont\nMarie Martin\nPaul Bernard", class: "font-mono" } %>

        <div class="pt-2">
          <%= f.submit "Créer les comptes",
              class: "w-full inline-flex items-center justify-center px-4 py-2 text-sm font-semibold rounded-lg bg-indigo-500 text-white hover:bg-indigo-600 transition-colors cursor-pointer" %>
        </div>
      </div>
    <% end %>
  </div>

  <div class="mt-4 text-center">
    <%= link_to "Retour à la classe", teacher_classroom_path(@classroom),
        class: "text-sm text-indigo-500 hover:text-indigo-400" %>
  </div>
</div>

<%# Extraction status partial %>
<div id="extraction-status" aria-live="polite" aria-atomic="true">
  <% job = subject.extraction_job %>
  <% if job %>
    <div class="flex flex-wrap items-center gap-3 mb-2">
      <span class="text-sm text-slate-600 dark:text-slate-400">Statut :</span>
      <%
        job_color = case job.status
                    when "pending"    then :slate
                    when "processing" then :amber
                    when "done"       then :emerald
                    when "failed"     then :rose
                    else :slate
                    end
      %>
      <%= render BadgeComponent.new(color: job_color, label: job.status) %>
      <% if job.provider_used %>
        <%= render BadgeComponent.new(color: :blue, label: "via #{job.provider_used}") %>
      <% end %>
    </div>

    <% if job.failed? %>
      <div class="rounded-lg bg-rose-50 dark:bg-rose-900/20 border border-rose-200 dark:border-rose-800 px-4 py-3 mb-3">
        <p class="text-sm text-rose-700 dark:text-rose-300">
          <span class="font-semibold">Erreur :</span> <%= job.error_message %>
        </p>
      </div>
      <%= button_to "Relancer l'extraction",
            teacher_subject_extraction_path(subject),
            method: :post,
            class: "inline-flex items-center justify-center font-semibold px-4 py-2 text-sm rounded-lg bg-indigo-500 text-white hover:bg-indigo-600 transition-colors cursor-pointer" %>
    <% end %>

    <% if job.processing? %>
      <p class="text-sm text-slate-500 dark:text-slate-400 flex items-center gap-2">
        <svg class="w-4 h-4 animate-spin text-indigo-500 shrink-0" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
          <path class="opacity-75" fill="currentColor"
                d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/>
        </svg>
        Extraction en cours…
        <% if job.updated_at %>
          <span class="text-slate-500 dark:text-slate-400">démarrée il y a <%= time_ago_in_words(job.updated_at) %></span>
        <% end %>
        <em class="not-italic text-slate-400">(la page se mettra à jour automatiquement)</em>
      </p>
    <% end %>
  <% else %>
    <p class="text-sm text-slate-500 dark:text-slate-400">Aucun job d'extraction.</p>
  <% end %>
</div>

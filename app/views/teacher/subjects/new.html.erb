<%# Nouveau sujet — new %>
<%= render BreadcrumbComponent.new(items: [
  { label: "Mes sujets", href: teacher_subjects_path },
  { label: "Nouveau sujet" }
]) %>

<div class="max-w-lg mx-auto">
  <h1 class="text-2xl font-bold text-slate-900 dark:text-white mb-6">Nouveau sujet</h1>

  <%= form_with model: [:teacher, @subject], multipart: true, class: "space-y-5" do |f| %>
    <% if @subject.errors.any? %>
      <div class="rounded-lg bg-rose-50 dark:bg-rose-900/20 border border-rose-200 dark:border-rose-800 px-4 py-3">
        <p class="text-sm font-semibold text-rose-700 dark:text-rose-400 mb-1">
          <%= pluralize(@subject.errors.count, "erreur") %> :
        </p>
        <ul class="list-disc list-inside space-y-0.5">
          <% @subject.errors.full_messages.each do |msg| %>
            <li class="text-sm text-rose-600 dark:text-rose-300"><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%# Session existante %>
    <h2 class="text-base font-semibold text-slate-700 dark:text-slate-300 border-b border-slate-200 dark:border-slate-700 pb-2">
      Session d'examen
    </h2>

    <div>
      <%= f.label :exam_session_id, "Session existante (optionnel)",
            class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1" %>
      <%= f.select :exam_session_id,
            options_from_collection_for_select(@exam_sessions, :id, :title, @subject.exam_session_id),
            { include_blank: "Nouvelle session" },
            class: "w-full px-4 py-2.5 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-sm text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent" %>
      <p class="mt-1 text-xs text-slate-500 dark:text-slate-400">
        Si aucune session n'est sélectionnée, une nouvelle sera créée automatiquement.
      </p>
    </div>

    <%# Metadata %>
    <h2 class="text-base font-semibold text-slate-700 dark:text-slate-300 border-b border-slate-200 dark:border-slate-700 pb-2 pt-2">
      Informations
    </h2>

    <%= render "teacher/shared/field", f: f, field: :title, label_text: "Titre", type: :text, options: { required: true } %>

    <%= render "teacher/shared/field", f: f, field: :year, label_text: "Année", type: :text, options: { placeholder: "2026", required: true } %>

    <%= render "teacher/shared/field", f: f, field: :exam, label_text: "Type d'examen", type: :select,
          collection: ExamSession.exams.keys.map { |k| [k.humanize, k] },
          options: { required: true } %>

    <%= render "teacher/shared/field", f: f, field: :specialty, label_text: "Spécialité", type: :select,
          collection: Subject.specialties.except("tronc_commun").keys.map { |k| [k, k] },
          options: { required: true } %>

    <%= render "teacher/shared/field", f: f, field: :region, label_text: "Région", type: :select,
          collection: [["Métropole", "metropole"], ["La Réunion", "reunion"], ["Polynésie", "polynesie"], ["Candidat libre", "candidat_libre"]],
          options: { required: true } %>

    <%# Files %>
    <h2 class="text-base font-semibold text-slate-700 dark:text-slate-300 border-b border-slate-200 dark:border-slate-700 pb-2 pt-2">
      Documents PDF
    </h2>

    <p class="text-sm text-slate-500 dark:text-slate-400">
      Les DTs et DRs sont extraits automatiquement du PDF sujet.
    </p>

    <%= render "teacher/shared/field", f: f, field: :subject_pdf, label_text: "Sujet complet (PDF)", type: :file, options: { accept: "application/pdf", required: true } %>

    <%= render "teacher/shared/field", f: f, field: :correction_pdf, label_text: "Corrigé complet (PDF)", type: :file, options: { accept: "application/pdf", required: true } %>

    <div class="pt-2">
      <%= render ButtonComponent.new(variant: :primary, size: :md, type: :submit) do %>
        Créer le sujet
      <% end %>
    </div>
  <% end %>
</div>

<%# Mes sujets — index %>
<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-slate-900 dark:text-white">Mes sujets</h1>
  <%= render ButtonComponent.new(href: new_teacher_subject_path, variant: :primary, pill: true) do %>
    Nouveau sujet
  <% end %>
</div>

<% if @pending_subjects.any? %>
  <div class="mb-6">
    <h2 class="text-base font-semibold text-slate-700 dark:text-slate-300 mb-3">En cours d'extraction…</h2>
    <div class="overflow-x-auto rounded-lg border border-amber-200 dark:border-amber-700">
      <table class="w-full text-sm">
        <thead class="bg-amber-50 dark:bg-amber-900/20">
          <tr>
            <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-amber-600 dark:text-amber-400">Importé le</th>
            <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-amber-600 dark:text-amber-400">Statut extraction</th>
            <th class="px-4 py-3"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-amber-100 dark:divide-amber-800/30 bg-white dark:bg-slate-900">
          <% @pending_subjects.each do |subject| %>
            <tr class="hover:bg-amber-50/50 dark:hover:bg-amber-900/10 transition-colors">
              <td class="px-4 py-3 text-slate-600 dark:text-slate-300">
                <%= subject.created_at.strftime("%d/%m/%Y %H:%M") %>
              </td>
              <td class="px-4 py-3">
                <% job = subject.extraction_job %>
                <% if job %>
                  <%
                    job_color = case job.status
                                when "pending"    then :slate
                                when "processing" then :amber
                                when "done"       then :emerald
                                when "failed"     then :rose
                                else :slate
                                end
                  %>
                  <%= render BadgeComponent.new(color: job_color, label: job.status) %>
                <% else %>
                  <span class="text-slate-400 text-xs">—</span>
                <% end %>
              </td>
              <td class="px-4 py-3 text-right">
                <%= link_to "Voir →", teacher_subject_path(subject),
                      class: "text-sm text-indigo-600 dark:text-indigo-400 hover:underline" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
<% end %>

<% if @subjects.empty? && @pending_subjects.empty? %>
  <p class="text-slate-500 dark:text-slate-400">Aucun sujet pour l'instant.</p>
<% elsif @subjects.any? %>
  <div class="overflow-x-auto rounded-lg border border-slate-200 dark:border-slate-700">
    <table class="w-full text-sm">
      <thead class="bg-slate-50 dark:bg-slate-800">
        <tr>
          <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400">Titre</th>
          <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400">Spécialité</th>
          <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400">Région</th>
          <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400">Année</th>
          <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400">Statut</th>
          <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400">Créé le</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-200 dark:divide-slate-700 bg-white dark:bg-slate-900">
        <% @subjects.each do |subject| %>
          <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/50 transition-colors">
            <td class="px-4 py-3">
              <%= link_to subject.title, teacher_subject_path(subject),
                    class: "font-medium text-indigo-600 dark:text-indigo-400 hover:underline" %>
            </td>
            <td class="px-4 py-3">
              <% if subject.specialty.present? %>
                <%= render BadgeComponent.new(color: :indigo, label: subject.specialty) %>
              <% end %>
            </td>
            <td class="px-4 py-3 text-slate-600 dark:text-slate-300"><%= subject.region %></td>
            <td class="px-4 py-3">
              <%= render BadgeComponent.new(color: :emerald, label: subject.year.to_s) %>
            </td>
            <td class="px-4 py-3">
              <%
                status_color = case subject.status
                               when "draft"               then :slate
                               when "pending_validation"  then :amber
                               when "published"           then :emerald
                               else :slate
                               end
              %>
              <%= render BadgeComponent.new(color: status_color, label: subject.status) %>
            </td>
            <td class="px-4 py-3 text-slate-500 dark:text-slate-400">
              <%= subject.created_at.strftime("%d/%m/%Y") %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>

<%# Sujet — show %>

<% subject_label = @subject.uploading? ? "Extraction en cours…" : (@subject.title.presence || "Sujet sans titre") %>

<%= render BreadcrumbComponent.new(items: [
  { label: "Mes sujets", href: teacher_subjects_path },
  { label: subject_label }
]) %>

<% if @subject.uploading? && @extraction_job %>
  <div class="mb-6">
    <%= render CardComponent.new(variant: :default) do |card| %>
      <% card.with_header do %>
        <h1 class="text-xl font-bold text-slate-900 dark:text-white">En cours d'extraction…</h1>
      <% end %>
      <% card.with_body do %>
        <% if @extraction_job.pending? || @extraction_job.processing? %>
          <%= turbo_frame_tag "extraction-polling" do %>
            <div class="flex items-center gap-3 py-2">
              <svg class="w-5 h-5 animate-spin text-indigo-500 shrink-0" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/>
              </svg>
              <p class="text-sm text-slate-600 dark:text-slate-400">Extraction en cours…</p>
            </div>
          <% end %>
          <meta http-equiv="refresh" content="3;url=<%= teacher_subject_path(@subject) %>">
        <% elsif @extraction_job.done? %>
          <div class="flex items-center justify-between gap-4">
            <p class="text-sm text-emerald-700 dark:text-emerald-400 font-medium">Extraction terminée.</p>
            <%= render ButtonComponent.new(href: teacher_subject_validation_path(@subject), variant: :primary, size: :sm) do %>
              Valider le sujet
            <% end %>
          </div>
        <% elsif @extraction_job.failed? %>
          <div class="rounded-lg bg-rose-50 dark:bg-rose-900/20 border border-rose-200 dark:border-rose-800 px-4 py-3">
            <p class="text-sm text-rose-700 dark:text-rose-300 font-semibold mb-2">L'extraction a échoué.</p>
            <p class="text-xs text-rose-600 dark:text-rose-400 mb-3"><%= @extraction_job.error_message %></p>
            <%= render ButtonComponent.new(href: teacher_subject_validation_path(@subject), variant: :ghost, size: :sm) do %>
              Valider quand même
            <% end %>
          </div>
        <% end %>
      <% end %>
    <% end %>
  </div>
<% else %>

<%# Card : métadonnées + documents PDF %>
<div class="mb-6">
  <%= render CardComponent.new(variant: :default) do |card| %>
    <% card.with_header do %>
      <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
        <div class="flex-1 min-w-0">
          <h1 class="text-2xl font-bold text-slate-900 dark:text-white mb-2 truncate">
            <%= @subject.title %>
          </h1>
          <div class="flex flex-wrap gap-1.5">
            <%
              status_color = case @subject.status
                             when "draft"               then :slate
                             when "pending_validation"  then :amber
                             when "published"           then :emerald
                             else :slate
                             end
            %>
            <%= render BadgeComponent.new(color: status_color, label: @subject.status) %>
            <% if @subject.specialty.present? %>
              <%= render BadgeComponent.new(color: :indigo, label: @subject.specialty) %>
            <% end %>
            <%= render BadgeComponent.new(color: :blue, label: @subject.exam) %>
            <%= render BadgeComponent.new(color: :emerald, label: @subject.year.to_s) %>
            <% if @subject.region.present? %>
              <%= render BadgeComponent.new(color: :slate, label: @subject.region) %>
            <% end %>
          </div>
        </div>
        <div class="flex flex-wrap gap-2 shrink-0">
          <%= render ButtonComponent.new(href: edit_teacher_subject_assignment_path(@subject), variant: :ghost, size: :sm) do %>
            Assigner aux classes
          <% end %>
        </div>
      </div>
    <% end %>
    <% card.with_body do %>
      <div class="border-t border-slate-200 dark:border-slate-700 -mx-5 px-5 pt-4">
        <h2 class="text-sm font-semibold text-slate-700 dark:text-slate-300 mb-2">Documents PDF</h2>
        <% if @subject.new_format? %>
          <%# New format: subject_pdf + correction_pdf %>
          <ul class="space-y-1">
            <% if @subject.subject_pdf.attached? %>
              <li>
                <%= link_to "Sujet complet",
                      rails_blob_path(@subject.subject_pdf, disposition: "attachment"),
                      class: "inline-flex items-center gap-1.5 text-sm text-indigo-600 dark:text-indigo-400 hover:underline" %>
              </li>
            <% end %>
            <% if @subject.correction_pdf.attached? %>
              <li>
                <%= link_to "Corrigé complet",
                      rails_blob_path(@subject.correction_pdf, disposition: "attachment"),
                      class: "inline-flex items-center gap-1.5 text-sm text-indigo-600 dark:text-indigo-400 hover:underline" %>
              </li>
            <% end %>
          </ul>
        <% else %>
          <%# Legacy format: 5 separate files %>
          <% attached_files = @subject.legacy_attached_files %>
          <% if attached_files.any? %>
            <ul class="space-y-1">
              <% attached_files.each do |file, label| %>
                <li>
                  <%= link_to label,
                        rails_blob_path(file, disposition: "attachment"),
                        class: "inline-flex items-center gap-1.5 text-sm text-indigo-600 dark:text-indigo-400 hover:underline" %>
                </li>
              <% end %>
            </ul>
          <% else %>
            <p class="text-sm text-slate-500 dark:text-slate-400">Aucun document attaché.</p>
          <% end %>
        <% end %>
      </div>
    <% end %>
  <% end %>
</div>

<% if @subject.exam_session.present? %>
  <%# Card : session d'examen %>
  <div class="mb-6">
    <%= render CardComponent.new(variant: :default) do |card| %>
      <% card.with_body do %>
        <div class="flex items-center gap-3">
          <p class="text-sm text-slate-600 dark:text-slate-400">
            Session :
            <span class="font-medium text-indigo-600 dark:text-indigo-400">
              <%= @subject.exam_session.title %>
            </span>
          </p>
          <%= button_to "Supprimer la session",
                teacher_exam_session_path(@subject.exam_session),
                method: :delete,
                form: { data: { turbo_confirm: "Supprimer la session « #{@subject.exam_session.title} » et toutes ses parties communes ? Cette action est irréversible." } },
                class: "text-xs text-red-500 hover:text-red-700 dark:text-red-400 dark:hover:text-red-300 underline underline-offset-2" %>
        </div>
      <% end %>
    <% end %>
  </div>
<% end %>

<%= turbo_stream_from "subject_#{@subject.id}" %>

<%# Extraction %>
<div class="mb-6">
  <h2 class="text-lg font-semibold text-slate-900 dark:text-white mb-3">Extraction</h2>
  <%= render "extraction_status", subject: @subject %>
</div>

<%# Parts list — unified partial handles both legacy and new-format %>
<%= render "parts_list", subject: @subject %>

<%# Stats + publish actions %>
<%= render "stats", subject: @subject %>

<%# Back link + archive action %>
<div class="mt-6 flex items-center justify-between gap-3">
  <%= render ButtonComponent.new(href: teacher_subjects_path, variant: :ghost, size: :sm) do %>
    ← Retour aux sujets
  <% end %>

  <%= button_to "Archiver le sujet",
        teacher_subject_path(@subject),
        method: :delete,
        form: { data: { turbo_confirm: "Archiver ce sujet ? Il disparaîtra de votre liste." } },
        class: "text-sm text-red-600 hover:text-red-700 dark:text-red-400 dark:hover:text-red-300 underline underline-offset-2" %>
</div>

<% end # end: unless @subject.uploading? %>

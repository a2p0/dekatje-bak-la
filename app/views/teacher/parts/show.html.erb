<div class="mb-6">
  <h1 class="text-2xl font-bold text-slate-900 dark:text-slate-100">
    <%= @subject.title %> — <%= @part.title %>
  </h1>
  <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">
    Objectif : <%= @part.objective_text %>
  </p>
</div>

<nav class="flex flex-wrap gap-2 mb-6">
  <% @parts.each do |part| %>
    <%= link_to part.title,
        teacher_subject_part_path(@subject, part),
        class: part == @part
          ? "px-3 py-1.5 text-xs font-semibold rounded-lg bg-indigo-500 text-white"
          : "px-3 py-1.5 text-xs font-semibold rounded-lg border border-slate-200 dark:border-slate-700 text-slate-600 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-800" %>
  <% end %>
</nav>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
  <div>
    <h2 class="text-lg font-semibold text-slate-900 dark:text-slate-100 mb-3">
      Questions (<%= @questions.count %>)
    </h2>

    <% if @questions.empty? %>
      <p class="text-sm text-slate-500 dark:text-slate-400">Aucune question dans cette partie.</p>
    <% else %>
      <div class="space-y-3">
        <% @questions.each do |question| %>
          <%= render "teacher/questions/question", question: question, subject: @subject, part: @part %>
        <% end %>
      </div>
    <% end %>
  </div>

  <div>
    <h2 class="text-lg font-semibold text-slate-900 dark:text-slate-100 mb-3">PDF Énoncé</h2>
    <% if @subject.enonce_file.attached? %>
      <iframe
        src="<%= rails_blob_path(@subject.enonce_file) %>"
        class="w-full rounded-lg border border-slate-200 dark:border-slate-700"
        height="800">
      </iframe>
    <% else %>
      <p class="text-sm text-slate-500 dark:text-slate-400">Aucun PDF joint à ce sujet.</p>
    <% end %>
  </div>
</div>

<div class="mt-6">
  <%= link_to "Retour au sujet", teacher_subject_path(@subject),
      class: "text-sm text-indigo-500 hover:text-indigo-400" %>
</div>

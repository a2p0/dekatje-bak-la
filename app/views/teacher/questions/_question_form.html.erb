<%= form_with url: teacher_question_path(question),
              scope: :question,
              method: :patch,
              data: { turbo_frame: dom_id(question) } do |f| %>
  <div class="mt-4 space-y-3 border-t border-slate-100 dark:border-slate-700 pt-4">
    <%= render "teacher/shared/field", f: f, field: :label, label_text: "Énoncé", type: :textarea, options: { value: question.label, rows: 3 } %>

    <%= render "teacher/shared/field", f: f, field: :points, label_text: "Points", type: :text, options: { value: question.points, step: 0.5, type: "number" } %>

    <% if question.answer %>
      <%= fields_for :answer, question.answer do |af| %>
        <%= render "teacher/shared/field", f: af, field: :correction_text, label_text: "Correction", type: :textarea, options: { rows: 3 } %>
        <%= render "teacher/shared/field", f: af, field: :explanation_text, label_text: "Explication", type: :textarea, options: { rows: 2 } %>
      <% end %>
    <% end %>

    <div class="flex items-center gap-3">
      <%= f.submit "Sauvegarder",
          class: "inline-flex items-center justify-center px-4 py-2 text-sm font-semibold rounded-lg bg-indigo-500 text-white hover:bg-indigo-600 transition-colors cursor-pointer" %>
    </div>
  </div>
<% end %>

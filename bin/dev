#!/usr/bin/env sh

# Start PostgreSQL and Redis containers if not running
if command -v podman-compose > /dev/null 2>&1; then
  if ! podman ps --format '{{.Names}}' | grep -q 'postgres' || \
     ! podman ps --format '{{.Names}}' | grep -q 'redis'; then
    echo "Starting PostgreSQL and Redis containers..."
    podman-compose up -d
  fi
elif command -v docker compose > /dev/null 2>&1; then
  if ! docker ps --format '{{.Names}}' | grep -q 'postgres' || \
     ! docker ps --format '{{.Names}}' | grep -q 'redis'; then
    echo "Starting PostgreSQL and Redis containers..."
    docker compose up -d
  fi
fi

if ! gem list foreman -i --silent; then
  echo "Installing foreman..."
  gem install foreman
fi

# Default to port 3000 if not specified
export PORT="${PORT:-3000}"

# Let the debug gem allow remote connections,
# but avoid loading until `debugger` is called
export RUBY_DEBUG_OPEN="true"
export RUBY_DEBUG_LAZY="true"

exec foreman start -f Procfile.dev "$@"
